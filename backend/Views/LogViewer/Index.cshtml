@{
    Layout = null;
    ViewData["Title"] = "服务端控制台";
}

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
</head>
<body>
<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: #0f1117;
        color: #e5e7eb;
        min-height: 100vh;
    }
    .dashboard {
            max-width: 900px;
            margin: 0 auto;
            padding: 48px 24px;
        }
        .dash-title {
            font-size: 28px;
            font-weight: 600;
            margin-bottom: 8px;
            color: #fff;
        }
        .dash-sub {
            font-size: 14px;
            color: #6b7280;
            margin-bottom: 40px;
        }
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 16px;
            margin-bottom: 32px;
        }
        .stat-card {
            background: #1a1d27;
            border: 1px solid #2a2d3a;
            border-radius: 12px;
            padding: 24px;
            text-align: center;
        }
        .stat-label {
            font-size: 12px;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }
        .stat-value {
            font-size: 36px;
            font-weight: 700;
            color: #fff;
            line-height: 1;
        }
        .stat-value.red { color: #ef4444; }
        .stat-value.yellow { color: #f59e0b; }
        .stat-value.blue { color: #3b82f6; }
        .stat-value.green { color: #22c55e; }
        .stat-desc {
            font-size: 12px;
            color: #4b5563;
            margin-top: 6px;
        }
        .section-title {
            font-size: 16px;
            font-weight: 600;
            color: #9ca3af;
            margin-bottom: 16px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .nav-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 16px;
        }
        .nav-card {
            background: #1a1d27;
            border: 1px solid #2a2d3a;
            border-radius: 12px;
            padding: 28px;
            text-decoration: none;
            color: inherit;
            transition: border-color 0.2s, transform 0.15s;
            display: block;
        }
        .nav-card:hover {
            border-color: #3b82f6;
            transform: translateY(-2px);
        }
        .nav-card-icon {
            font-size: 36px;
            margin-bottom: 12px;
        }
        .nav-card-title {
            font-size: 18px;
            font-weight: 600;
            color: #fff;
            margin-bottom: 6px;
        }
        .nav-card-desc {
            font-size: 13px;
            color: #6b7280;
            line-height: 1.5;
        }
        .nav-card-arrow {
            margin-top: 16px;
            color: #3b82f6;
            font-size: 14px;
            font-weight: 500;
        }
    </style>
    <div class="dashboard">
        <div class="dash-title">📊 服务端控制台</div>
        <div class="dash-sub">服务状态总览 · @DateTime.Now.ToString("yyyy-MM-dd HH:mm")</div>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-label">今日 Error</div>
                <div class="stat-value red">@ViewData["TodayErrorCount"]</div>
                <div class="stat-desc">条错误日志</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">总记录数</div>
                <div class="stat-value blue">@ViewData["TotalCount"]</div>
                <div class="stat-desc">所有日志</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">最后上报</div>
                <div class="stat-value green" style="font-size:16px;padding-top:10px">@ViewData["LastLogTime"]</div>
                <div class="stat-desc">最近一条</div>
            </div>
        </div>

        <div class="section-title">功能面板</div>
        <div class="nav-grid">
            <a class="nav-card" href="/logViewer/errors">
                <div class="nav-card-icon">🔍</div>
                <div class="nav-card-title">错误日志查看器</div>
                <div class="nav-card-desc">查看、搜索、过滤服务器错误日志，支持多条件筛选与分页。</div>
                <div class="nav-card-arrow">进入 →</div>
            </a>
        </div>
    </div>
</body>
</html>

